{
  "compilerOptions": {
 "target": "esnext",
 "module": "esnext",
 "jsx": "react-jsx",
 "strict": true,
 "moduleResolution": "node",
 "resolveJsonModule": true,
 "esModuleInterop": true,
 "skipLibCheck": true,
 "allowSyntheticDefaultImports": true,
 "baseUrl": "."
  },
  "include": ["/*.ts", "/.tsx", "**/.js"],
  "exclude": ["node_modules"]
}
